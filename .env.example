NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key
OPENAI_API_KEY=optional_for_document_generation
GROQ_API_KEY=optional_for_cv_analysis
GEMINI_API_KEY=optional_for_cv_analysis

# Job connector sync
CRON_SECRET=random_secret_for_cron_endpoint

# ATS boards (optional — company slugs from the job board URL)
GREENHOUSE_BOARD_TOKENS=stripe,airbnb
LEVER_COMPANIES=netflix,spotify

# Remote job boards (enabled by default — set to false to disable)
REMOTEOK_ENABLED=true
REMOTIVE_ENABLED=true
REMOTIVE_CATEGORIES=software-dev,devops-sysadmin,product,data,qa
WWR_ENABLED=true
WWR_CATEGORIES=remote-programming-jobs,remote-devops-sysadmin-jobs,remote-product-jobs
REMOTE_CO_ENABLED=true
GETMANFRED_ENABLED=true

# Wellfound (may be blocked by anti-bot on servers)
WELLFOUND_ENABLED=true
WELLFOUND_ROLE_SLUGS=frontend-engineer,backend-engineer,devops-engineer,product-manager

# InfoJobs Spain (requires developer credentials — see below)
INFOJOBS_ENABLED=true
INFOJOBS_CLIENT_ID=your_infojobs_client_id
INFOJOBS_CLIENT_SECRET=your_infojobs_client_secret
# Leave empty to search all of Spain. Or comma-separated province slugs:
# INFOJOBS_PROVINCES=sevilla,madrid,valencia,barcelona
INFOJOBS_PROVINCES=

# Extra keywords merged with onboarding skills and track defaults
JOB_SYNC_KEYWORDS=devops,backend,platform engineer,product manager,data engineer,security engineer
